APP_ENV=local

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pegaso_web_services_DB
DB_USER=NOMBRE_USUARIO_BD
DB_PASS=TU_PASSWORD_AQUI

DB_CHARSET=utf8mb4

LOG_PATH=logs/error.log

# ── PayPal (Fase 1 de pago) ───────────────────────────────────
# Obtener credenciales en developer.paypal.com → My Apps & Credentials
# PAYPAL_MODE: "sandbox" para pruebas | "live" para producción
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=TU_CLIENT_ID_AQUI
PAYPAL_CLIENT_SECRET=TU_CLIENT_SECRET_AQUI

# ── Frontend Next.js ──────────────────────────────────────────
# Copiar también a booking-engine/.env.local
NEXT_PUBLIC_API_URL=http://localhost/PegasoExpedicionesDev/api
NEXT_PUBLIC_CONTACT_PHONE=521XXXXXXXXXX
